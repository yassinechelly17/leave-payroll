# Standalone dev (backend on :8082, no gateway)
BACKEND_URL=http://127.0.0.1:8082/api/v1

# Platform stack (make up-platform in attendance-platform) — optional local override:
# BACKEND_URL=http://localhost:8090/api/leave

# NextAuth + Keycloak Authorization Code (PKCE) sign-in — server-side only. Reuses the public
# "demo-client" (same one auth-service-frontend and punch-clock-frontend use) — unrelated to the
# confidential "leave-payroll-backend" client used by this app's *backend* for its own
# server-to-server OpenFeign/client-credentials calls to punch-clock.
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=dev-secret-change-me
KEYCLOAK_CLIENT_ID=demo-client
# Running `npm run dev` on the host (not Docker): browser and server reach Keycloak the same
# way, so both vars below point at the same host-exposed URL (unlike in Docker, where the
# server uses the internal auth-keycloak:8080 hostname instead — see
# compose.services.d/leave-payroll.yaml).
KEYCLOAK_ISSUER_URI=http://localhost:9090/realms/workforce-os
KEYCLOAK_BROWSER_URL=http://localhost:9090
