# Standalone dev (backend on :8082, no gateway)
BACKEND_URL=http://127.0.0.1:8082/api/v1
DEV_BYPASS_AUTH=true

# Platform stack (make up-platform in attendance-platform) — optional local override:
# BACKEND_URL=http://localhost:8090/api/leave

# When Keycloak container is running:
# DEV_BYPASS_AUTH=false
# KEYCLOAK_TOKEN_URL=http://localhost:8180/realms/workforce-realm/protocol/openid-connect/token
# KEYCLOAK_CLIENT_ID=api-gateway
# KEYCLOAK_CLIENT_SECRET=api-gateway-secret
